# Elasticsearch credentials
ES_USERNAME=your_es_username
ES_PASSWORD=your_es_password

# Elasticsearch API key (alternative to username/password)
ES_API_KEY=your_es_api_key

# Kubernetes credentials (optional, needed only if running outside cluster).
# Prefer setting kubernetes.context in each config/profile instead of a global
# K8S_CONTEXT override.
# K8S_CONTEXT=production-cluster
K8S_KUBECONFIG=/path/to/kubeconfig
K8S_SERVICE_ACCOUNT_TOKEN=your_sa_token

# LLM API key. Hosted providers require a real key; local OpenAI-compatible
# servers commonly accept any non-empty value, such as "local".
LLM_API_KEY=local

# Email settings for automated abuse reports.
# Do not pass these as CLI flags; environment variables avoid exposing secrets
# in the process list.
# Prefer setting provider/from/sandbox in each config/profile. Use these only
# when you want one global override for every profile.
# EMAIL_PROVIDER=mailjet
# EMAIL_FROM_EMAIL=abuse@example.com
# EMAIL_FROM_NAME=DevOps Agent Abuse Reports
# EMAIL_SANDBOX_MODE=false

# Mailjet credentials.
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret
MAILJET_ENDPOINT=https://api.mailjet.com/v3.1/send

# Postmark credentials. Use POSTMARK_API_TEST for request validation without
# delivery, or set EMAIL_SANDBOX_MODE=true.
POSTMARK_SERVER_TOKEN=your_postmark_server_token
POSTMARK_ENDPOINT=https://api.postmarkapp.com/email
POSTMARK_MESSAGE_STREAM=outbound
